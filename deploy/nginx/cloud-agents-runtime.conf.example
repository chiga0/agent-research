server {
    listen 80;
    listen [::]:80;
    server_name __PUBLIC_HOST__;

    location = /cloud-agents {
        return 302 /cloud-agents/;
    }

    location = /cloud-agents/ {
        auth_basic "Cloud Agents Runtime";
        auth_basic_user_file /etc/nginx/cloud-agents.htpasswd;
        default_type text/html;
        return 200 '<!doctype html><html><head><meta charset="utf-8"><title>Cloud Agents Runtime</title></head><body><h1>Cloud Agents Runtime</h1><ul><li><a href="/cloud-agents/health">health</a></li><li><a href="/cloud-agents/capabilities">capabilities</a></li><li><a href="/cloud-agents/runs">runs</a></li></ul></body></html>';
    }

    location /cloud-agents/ {
        auth_basic "Cloud Agents Runtime";
        auth_basic_user_file /etc/nginx/cloud-agents.htpasswd;

        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        include /etc/nginx/snippets/cloud-agents-runtime-auth.conf;
        proxy_buffering off;
        proxy_cache off;
        proxy_read_timeout 3600s;
        proxy_send_timeout 3600s;
        proxy_pass http://127.0.0.1:8765/;
    }
}
