RUN_MANAGER_TOKEN=change-me
QWEN_SERVER_TOKEN=change-me-too
QWEN_SERVE_URL=http://127.0.0.1:4170
QWEN_SERVE_TOKEN=change-me-too
QWEN_SERVE_COMMAND=qwen serve --hostname 127.0.0.1 --port 4170 --workspace /var/lib/cloud-agents-runtime/workspace --no-web --require-auth
QWEN_SERVE_CWD=/var/lib/cloud-agents-runtime/workspace
QWEN_SERVE_STARTUP_TIMEOUT=30
